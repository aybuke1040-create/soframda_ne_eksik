rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /requests/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /delivery_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /design_requests/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /profile_photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /recipes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
