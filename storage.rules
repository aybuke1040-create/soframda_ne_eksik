rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isImageUpload() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    match /requests/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isImageUpload();
    }

    match /delivery_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isImageUpload();
    }

    match /design_requests/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isImageUpload();
    }

    match /profile_photos/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        fileName == request.auth.uid + '.jpg' &&
        isImageUpload();
    }

    match /recipes/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
