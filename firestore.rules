rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        (
          exists(/databases/$(database)/documents/app_config/moderation) &&
          get(/databases/$(database)/documents/app_config/moderation).data.adminUserIds is list &&
          request.auth.uid in get(/databases/$(database)/documents/app_config/moderation).data.adminUserIds
        )
      );
    }

    function protectedUserFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'credit',
        'credits',
        'ratingAverage',
        'ratingCount',
        'completedOrders',
        'role',
        'isAdmin',
        'fcmToken',
        'latitude',
        'longitude',
        'pushUpdatedAt',
        'locationUpdatedAt',
      ]) &&
      // Eski herkese açık iletişim alanları yalnızca silinebilir. Kullanıcı
      // istemcisi bu alanları ekleyemez veya mevcut değerlerini değiştiremez.
      (!('email' in request.resource.data) ||
        (('email' in resource.data) &&
          request.resource.data.email == resource.data.email)) &&
      (!('phoneNumber' in request.resource.data) ||
        (('phoneNumber' in resource.data) &&
          request.resource.data.phoneNumber == resource.data.phoneNumber));
    }

    function isChatParticipant(chatData) {
      return isSignedIn() && request.auth.uid in chatData.users;
    }

    function chatIdLooksAccessible(chatId) {
      return isSignedIn() && (
        chatId.matches('^' + request.auth.uid + '_[^_]+_.+$') ||
        chatId.matches('^[^_]+_' + request.auth.uid + '_.+$')
      );
    }

    function protectedRequestFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'ownerId',
        'acceptedOfferId',
        'acceptedUserId',
        'ownerCompleted',
        'workerCompleted',
        'completedProcessed',
        'reviewByOwner',
        'reviewByWorker',
        'createdAt',
      ]);
    }

    function requestAcceptsReadyFoodOrder(requestId) {
      return exists(/databases/$(database)/documents/requests/$(requestId)) &&
        (
          get(/databases/$(database)/documents/requests/$(requestId)).data.type == 'ready_food' ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.requestType == 'ready_food' ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.isReady == true
        ) &&
        (
          !('status' in get(/databases/$(database)/documents/requests/$(requestId)).data) ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.status in ['open', 'active']
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId) &&
        !request.resource.data.keys().hasAny([
          'credit',
          'credits',
          'role',
          'isAdmin',
          'email',
          'phoneNumber',
          'fcmToken',
          'latitude',
          'longitude',
          'pushUpdatedAt',
          'locationUpdatedAt',
        ]) &&
        (!('ratingAverage' in request.resource.data) ||
          request.resource.data.ratingAverage == 0) &&
        (!('ratingCount' in request.resource.data) ||
          request.resource.data.ratingCount == 0) &&
        (!('completedOrders' in request.resource.data) ||
          request.resource.data.completedOrders == 0);
      allow update: if isSelf(userId) && protectedUserFieldsUnchanged();
      allow delete: if false;

      match /private/{documentId} {
        allow read, write: if isSelf(userId);

        match /{subCollection}/{docId} {
          allow read, write: if isSelf(userId);
        }
      }
    }

    match /users/{userId}/credit_history/{historyId} {
      allow read: if isSelf(userId);
      allow write: if false;
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isSelf(userId);
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        resource.data.ownerId == request.auth.uid &&
        protectedRequestFieldsUnchanged();

      match /orders/{orderId} {
        allow read: if isSignedIn() && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.ownerId == request.auth.uid
        );
        allow create: if isSignedIn() &&
          orderId == request.auth.uid &&
          requestAcceptsReadyFoodOrder(requestId) &&
          request.resource.data.keys().hasOnly([
            'buyerId',
            'ownerId',
            'status',
            'title',
            'createdAt',
          ]) &&
          request.resource.data.buyerId == request.auth.uid &&
          (
            !('ownerId' in request.resource.data) ||
            request.resource.data.ownerId ==
              get(/databases/$(database)/documents/requests/$(requestId)).data.ownerId
          ) &&
          get(/databases/$(database)/documents/requests/$(requestId)).data.ownerId !=
            request.auth.uid &&
          request.resource.data.status == 'pending' &&
          request.resource.data.title is string &&
          request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() &&
        resource.data.senderId == request.auth.uid &&
        resource.data.status == 'pending';
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
        resource.data.receiverId == request.auth.uid;
      allow write: if false;
    }

    match /moderation_reports/{reportId} {
      allow read: if isAdmin();
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'reviewedAt', 'adminNote']) &&
        request.resource.data.status in ['open', 'reviewed', 'resolved', 'dismissed'];
      allow create, delete: if false;
    }

    match /app_config/client {
      allow read: if true;
      allow write: if false;
    }

    match /admin_broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /chats/{chatId} {
      allow read: if (resource != null && isChatParticipant(resource.data)) ||
        (resource == null && chatIdLooksAccessible(chatId));
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'users',
          'participants',
          'requestId',
          'lastMessage',
          'lastMessageTime',
          'names',
          'photos',
        ]) &&
        request.resource.data.users is list &&
        request.resource.data.users.size() == 2 &&
        request.auth.uid in request.resource.data.users &&
        request.resource.data.participants is map &&
        request.resource.data.requestId is string &&
        request.resource.data.lastMessage is string;
      allow update: if isChatParticipant(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deletedFor',
        ]) &&
        request.resource.data.users == resource.data.users &&
        request.resource.data.participants == resource.data.participants &&
        request.resource.data.requestId == resource.data.requestId &&
        request.resource.data.lastMessage == resource.data.lastMessage &&
        request.resource.data.lastMessageTime == resource.data.lastMessageTime &&
        request.resource.data.names == resource.data.names &&
        request.resource.data.photos == resource.data.photos &&
        request.resource.data.firstMessagePaidUsers ==
          resource.data.firstMessagePaidUsers &&
        request.resource.data.deletedFor[request.auth.uid] == true;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data
        );
        allow write: if false;
      }
    }

    match /user_chats/{userId}/chats/{chatId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
