rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function protectedUserFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'credit',
        'credits',
        'ratingAverage',
        'ratingCount',
        'completedOrders',
      ]);
    }

    function isChatParticipant(chatData) {
      return isSignedIn() && request.auth.uid in chatData.users;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) && protectedUserFieldsUnchanged();
      allow delete: if false;

      match /private/{documentId} {
        allow read, write: if isSelf(userId);
      }
    }

    match /users/{userId}/credit_history/{historyId} {
      allow read: if isSelf(userId);
      allow write: if false;
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isSelf(userId);
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.acceptedOfferId == resource.data.acceptedOfferId &&
        request.resource.data.acceptedUserId == resource.data.acceptedUserId &&
        request.resource.data.ownerCompleted == resource.data.ownerCompleted &&
        request.resource.data.workerCompleted == resource.data.workerCompleted &&
        request.resource.data.completedProcessed == resource.data.completedProcessed &&
        request.resource.data.reviewByOwner == resource.data.reviewByOwner &&
        request.resource.data.reviewByWorker == resource.data.reviewByWorker;

      match /orders/{orderId} {
        allow read: if isSignedIn() && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.ownerId == request.auth.uid
        );
        allow create: if isSignedIn() &&
          request.resource.data.buyerId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() &&
        resource.data.senderId == request.auth.uid &&
        resource.data.status == 'pending';
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
        resource.data.receiverId == request.auth.uid;
      allow write: if false;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(resource.data);
      allow create: if isSignedIn() &&
        request.resource.data.users is list &&
        request.resource.data.users.size() == 2 &&
        request.auth.uid in request.resource.data.users &&
        request.resource.data.requestId is string;
      allow update: if isChatParticipant(resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data
        );
        allow write: if false;
      }
    }

    match /user_chats/{userId}/chats/{chatId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
